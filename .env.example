# Copy to .env and fill in your values. .env is gitignored — never commit real keys.
# Run via ./run.sh which sources this file automatically.

# ---- Required ---------------------------------------------------------------
# Realtime API key (billed ~$32/$64 per 1M audio input/output tokens).
OPENAI_API_KEY=sk-proj-...

# ---- Audio ------------------------------------------------------------------
# Substring of your mic's device name (e.g. "Scarlett", "MacBook").
# Leave unset to use the system default input.
# VOICEOS_MIC=Scarlett

# ---- Model / voice ----------------------------------------------------------
# VOICEOS_MODEL=gpt-realtime-2
# VOICEOS_VOICE=marin

# ---- Wake word (cloud mode, voice_agent.py) ---------------------------------
# VOICEOS_WAKE_WORD=hey chat

# ---- Local wake engine (wake_listener.py --local) ---------------------------
# OWW model: built-in options are hey_jarvis, hey_mycroft, alexa.
# Set to an absolute path to load a custom .onnx/.tflite model.
# VOICEOS_OWW_MODEL=hey_jarvis

# Detection sensitivity: 0.0 (very sensitive) → 1.0 (very strict). Default 0.5.
# VOICEOS_OWW_THRESHOLD=0.5

# Whisper model size for command transcription after wake fires.
# Options: tiny.en, base.en, small.en
# VOICEOS_WHISPER=base.en

# ---- Browser ----------------------------------------------------------------
# Which browser web_search opens URLs in (must be AppleScript-scriptable).
# Common options: Safari, Google Chrome, Arc, Firefox
# VOICEOS_BROWSER=Safari

# ---- User persona -----------------------------------------------------------
# Your name — the assistant uses this to address you.
# VOICEOS_USER_NAME=Alex

# Free-text hints added to the system prompt (accent, preferences, etc.).
# VOICEOS_USER_HINTS=The user has a New Zealand accent.

# ---- App versions -----------------------------------------------------------
# Exact macOS app name for Premiere Pro (update when you upgrade).
# VOICEOS_PREMIERE_APP=Adobe Premiere Pro 2025
