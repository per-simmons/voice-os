# Copy to .env and fill in your values. .env is gitignored — never commit real keys.
# Run via ./run.sh which sources this file automatically.

# ---- Required ---------------------------------------------------------------
# Realtime API key (billed ~$32/$64 per 1M audio input/output tokens).
OPENAI_API_KEY=sk-proj-...

# ---- Audio ------------------------------------------------------------------
# Substring of your mic's device name (e.g. "Scarlett", "MacBook").
# Leave unset to use the system default input.
# VOICEOS_MIC=Scarlett

# ---- Model / voice ----------------------------------------------------------
# VOICEOS_MODEL=gpt-realtime-2
# VOICEOS_VOICE=marin

# ---- Transcription (cloud modes: push-to-talk / hotkey / --wake) ------------
# Model that turns speech into text in the cloud modes. Bigger = more accurate
# but billed per audio minute (and --wake transcribes continuously).
# Options: gpt-4o-transcribe (best) · gpt-4o-mini-transcribe (cheaper) · whisper-1
# VOICEOS_TRANSCRIBE_MODEL=gpt-4o-transcribe
# VOICEOS_TRANSCRIBE_LANGUAGE=en
# Biasing hint that cuts mishears of short commands. Set to "" to disable.
# VOICEOS_TRANSCRIBE_PROMPT=Commands to a Mac voice assistant; they start with "hey chat".

# ---- Wake word (cloud mode: ./run.sh --wake) --------------------------------
# VOICEOS_WAKE_WORD=hey chat

# ---- Local wake engine ($0 idle: ./run.sh --local) --------------------------
# Wake word + transcription run on-device; the cloud is only called once you
# speak the wake word, so idle listening is free.
#
# OWW model: built-in options are hey_jarvis, hey_mycroft, alexa (NOT "hey chat"
# — that needs a custom-trained model). Or an absolute path to a .onnx/.tflite.
# VOICEOS_OWW_MODEL=hey_jarvis

# Detection sensitivity: 0.0 (very sensitive) → 1.0 (very strict). Default 0.5.
# VOICEOS_OWW_THRESHOLD=0.5

# Local Whisper size for the command, transcribed on-device after wake fires.
# Bigger = more accurate; costs CPU per-command but NOTHING at idle.
# smallest→best: tiny.en  base.en  small.en  medium.en  distil-large-v3  large-v3
# VOICEOS_WHISPER=small.en

# Local sentence-transformers model for capability retrieval.
# Downloaded automatically on first run (~22 MB). Runs fully offline.
# VOICEOS_EMBED_MODEL=all-MiniLM-L6-v2

# ---- Browser ----------------------------------------------------------------
# Which browser web_search opens URLs in (must be AppleScript-scriptable).
# Common options: Safari, Google Chrome, Arc, Firefox
# VOICEOS_BROWSER=Safari

# ---- User persona -----------------------------------------------------------
# Your name — the assistant uses this to address you.
# VOICEOS_USER_NAME=Alex

# Free-text hints added to the system prompt (accent, preferences, etc.).
# VOICEOS_USER_HINTS=The user has a New Zealand accent.

# ---- Spotify favorites ------------------------------------------------------
# Path to a JSON file mapping spoken phrases to spotify:track:<id> URIs.
# Example file contents: {"watermelon man": "spotify:track:38xcUjiTP1ivfb7ObwjyGA"}
# Grab track IDs from a song's Spotify URL. If unset, only generic search is used.
# VOICEOS_SPOTIFY_FAVORITES=/Users/yourname/.config/voiceos/favorites.json

# ---- Claude Desktop project -------------------------------------------------
# Name of the Claude Desktop project ask_claude navigates into.
# VOICEOS_CLAUDE_PROJECT=YouTube Script

# A short unique phrase from that project's system prompt to detect when we're
# already inside it (avoids re-navigating on every call). Must be lowercase.
# VOICEOS_CLAUDE_PROJECT_HINT=you are helping with a youtube script

# ---- App versions -----------------------------------------------------------
# Exact macOS app name for Premiere Pro (update when you upgrade).
# VOICEOS_PREMIERE_APP=Adobe Premiere Pro 2025
